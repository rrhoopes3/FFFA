# Congress.gov API key (free: https://api.congress.gov/sign-up/)
CONGRESS_API_KEY=your_key_here

# ── AI Provider Selection ──────────────────────────────────
# Options: "ollama", "claude", "openai"
# Ollama = free (runs on your GPU). Cloud providers = fallback.
AI_PROVIDER=ollama

# ── Ollama (local GPU / Cloudflare Tunnel) ─────────────────
# Local: http://localhost:11434
# Remote via Cloudflare Tunnel: https://ollama.omnibusai.info
OLLAMA_BASE_URL=http://localhost:11434

# Models for RTX 3090 (24GB VRAM):
#   Quality: qwen2.5:32b-instruct-q4_K_M (divisions, ~20GB VRAM)
#   Fast:    qwen2.5:14b-instruct-q5_K_M (sections, ~12GB VRAM)
#   Fastest: llama3.1:8b-instruct        (sections, ~5GB VRAM)
OLLAMA_SMART_MODEL=qwen2.5:32b-instruct-q4_K_M
OLLAMA_FAST_MODEL=qwen2.5:14b-instruct-q5_K_M

# Context window (tokens). Tradeoff: larger = more VRAM for KV cache.
#   32B model: use 32768 (safe) or 16384 (conservative)
#   14B model: use 65536
#   8B model:  use 131072
OLLAMA_NUM_CTX=32768

# Cloudflare Access auth (for remote tunnel to your GPU)
# Create at: Cloudflare Zero Trust → Access → Service Tokens
# CF_ACCESS_CLIENT_ID=your_id_here
# CF_ACCESS_CLIENT_SECRET=your_secret_here

# ── Cloud Providers (optional fallback) ────────────────────
# ANTHROPIC_API_KEY=your_key_here
# OPENAI_API_KEY=your_key_here

# Override cloud models if needed:
# CLAUDE_FAST_MODEL=claude-haiku-4-5-20251001
# CLAUDE_SMART_MODEL=claude-sonnet-4-6-20250514
# OPENAI_FAST_MODEL=gpt-4o-mini
# OPENAI_SMART_MODEL=gpt-4o
